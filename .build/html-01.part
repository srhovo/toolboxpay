erflow:hidden;flex-direction:column;padding:23px;border-radius:var(--radius-lg);border:1px solid rgba(255,255,255,.9);background:linear-gradient(125deg,rgba(255,255,255,.54),transparent 46%),linear-gradient(148deg,var(--tone-1),var(--tone-2));box-shadow:var(--shadow-soft);transition:transform .22s ease,box-shadow .22s ease;isolation:isolate}.service-card::before{content:"";position:absolute;z-index:-1;width:170px;height:170px;left:-108px;top:-103px;border-radius:50%;background:rgba(255,255,255,.48)}.service-card::after{content:"";position:absolute;z-index:-1;width:172px;height:172px;right:-77px;bottom:-88px;border-radius:50%;background:rgba(255,255,255,.39);box-shadow:inset 0 0 0 1px rgba(255,255,255,.22)}.service-card:active{transform:scale(.988)}.service-card.is-recommended{box-shadow:0 22px 54px rgba(81,117,166,.16);border-color:rgba(255,255,255,.98)}.service-card.is-target{outline:3px solid rgba(255,255,255,.9);box-shadow:0 0 0 5px rgba(91,134,215,.13),var(--shadow)}.mint{--tone-1:var(--mint-1);--tone-2:var(--mint-2);--tone-ink:var(--mint-ink);--tone-deep:var(--mint-deep);--tone-deep-2:var(--mint-deep-2)}.sky{--tone-1:var(--sky-1);--tone-2:var(--sky-2);--tone-ink:var(--sky-ink);--tone-deep:var(--sky-deep);--tone-deep-2:var(--sky-deep-2)}.peach{--tone-1:var(--peach-1);--tone-2:var(--peach-2);--tone-ink:var(--peach-ink);--tone-deep:var(--peach-deep);--tone-deep-2:var(--peach-deep-2)}.lilac{--tone-1:var(--lilac-1);--tone-2:var(--lilac-2);--tone-ink:var(--lilac-ink);--tone-deep:var(--lilac-deep);--tone-deep-2:var(--lilac-deep-2)}.card-top{position:relative;z-index:1;display:flex;align-items:flex-start;justify-content:space-between;gap:12px}.icon-box{display:grid;place-items:center;width:51px;height:51px;border-radius:18px;color:var(--tone-ink);background:rgba(255,255,255,.68);box-shadow:inset 0 0 0 1px rgba(255,255,255,.78),0 8px 20px rgba(75,95,126,.07)}.icon-box svg{width:27px;height:27px}.tag{min-height:27px;display:inline-flex;align-items:center;padding:6px 11px;border-radius:999px;color:var(--tone-ink);background:rgba(255,255,255,.62);border:1px solid rgba(255,255,255,.7);font-size:10px;font-weight:800;letter-spacing:.04em}.tag.recommend{display:none}.is-recommended .tag.default{display:none}.is-recommended .tag.recommend{display:inline-flex}.service-card h3{position:relative;z-index:1;margin:25px 0 8px;font-size:23px;line-height:1.25;letter-spacing:-.03em}.service-card .desc{position:relative;z-index:1;margin:0;min-height:44px;color:rgba(45,52,69,.66);font-size:13px;line-height:1.68}.account{position:relative;z-index:1;margin-top:13px;color:var(--tone-ink);font-size:12px;font-weight:760}.actions{position:relative;z-index:1;display:grid;gap:9px;margin-top:auto;padding-top:24px}.btn{min-height:49px;display:inline-flex;align-items:center;justify-content:center;gap:7px;border-radius:16px;padding:0 15px;font-size:13px;font-weight:760;transition:transform .16s ease,opacity .16s ease,background .16s ease,box-shadow .16s ease}.btn:active{transform:scale(.975);opacity:.88}.btn.primary{color:#fff;background:linear-gradient(135deg,var(--tone-deep),var(--tone-deep-2));box-shadow:0 11px 24px rgba(65,89,126,.16)}.btn.secondary{color:var(--tone-ink);background:rgba(255,255,255,.67);border:1px solid rgba(255,255,255,.8);box-shadow:inset 0 1px 0 rgba(255,255,255,.74)}.btn-row{display:grid;grid-template-columns:1fr 1fr;gap:9px}.note-card{margin-top:18px;padding:20px 21px;border-radius:23px;border:1px solid rgba(255,255,255,.88);background:linear-gradient(145deg,rgba(255,255,255,.75),rgba(238,247,255,.68));backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);box-shadow:var(--shadow-soft)}.note-card strong{display:block;margin-bottom:7px;font-size:13px}.note-card p{margin:0;color:var(--muted);font-size:12px;line-height:1.75}.footer{padding:32px 8px 6px;text-align:center;color:var(--soft);font-size:11px;line-height:1.8}.sheet{position:fixed;inset:0;z-index:50;display:flex;align-items:flex-end;justify-content:center;padding:16px;padding-bottom:calc(16px + env(safe-area-inset-bottom));background:rgba(45,58,78,.28);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);opacity:0;pointer-events:none;transition:opacity .24s ease}.sheet[hidden]{display:none}.sheet.show{opacity:1;pointer-events:auto}.sheet-panel{width:min(560px,100%);max-height:min(86vh,820px);overflow:auto;border-radius:32px;background:linear-gradient(180deg,#fcfeff,#f8fbff);border:1px solid rgba(255,255,255,.92);box-shadow:0 28px 78px rgba(42,58,82,.27);transform:translateY(18px) scale(.985);transition:transform .24s ease}.sheet.show .sheet-panel{transform:translateY(0) scale(1)}.sheet-head{position:sticky;top:0;z-index:2;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:19px 20px 15px;background:rgba(250,253,255,.93);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--line)}.sheet-title{min-width:0}.sheet-title h2{margin:0;font-size:18px}.sheet-title p{margin:4px 0 0;color:var(--soft);font-size:11px}.close{width:38px;height:38px;flex:0 0 auto;display:grid;place-items:center;border-radius:50%;color:var(--muted);background:#eef5fb;font-size:21px}.qr-wrap{padding:18px;background:linear-gradient(145deg,#eef7ff,#f8fbff)}.qr-image{display:block;width:100%;max-height:64vh;object-fit:contain;border-radius:21px;background:#fff;box-shadow:0 12px 32px rgba(65,88,119,.1);-webkit-touch-callout:default;user-select:auto}.sheet-foot{display:grid;gap:11px;padding:16px 19px 20px}.sheet-hint{margin:0;color:var(--muted);font-size:12px;line-height:1.7;text-align:center}.sheet-foot .btn{width:100%;color:#fff;background:linear-gradient(135deg,#4a6f9f,#6387b8)}.guide-body{padding:20px}.guide-lead{margin:0 0 16px;color:var(--muted);font-size:13px;line-height:1.75}.steps{display:grid;gap:11px}.step{display:grid;grid-template-columns:32px 1fr;align-items:start;gap:12px;padding:14px;border-radius:19px;background:linear-gradient(145deg,#f1f7ff,#f8fbff);border:1px solid rgba(216,235,255,.7)}.step-num{width:31px;height:31px;display:grid;place-items:center;border-radius:11px;color:#5273a7;background:#dcecff;font-size:12px;font-weight:800}.step h3{margin:1px 0 5px;font-size:13px}.step p{margin:0;color:var(--muted);font-size:12px;line-height:1.6}.guide-actions{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-top:16px}.guide-actions .btn:first-child{color:#52709b;background:#e7f1fc}.guide-actions .btn:last-child{color:#fff;background:linear-gradient(135deg,#4f6f9a,#6689b9)}.toast{position:fixed;z-index:80;left:50%;bottom:calc(26px + env(safe-area-inset-bottom));transform:translate(-50%,12px);max-width:calc(100% - 32px);padding:12px 18px;border-radius:999px;color:#fff;background:rgba(45,54,70,.94);box-shadow:0 14px 36px rgba(38,47,62,.23);font-size:12px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .2s ease,transform .2s ease}.toast.show{opacity:1;transform:translate(-50%,0)}@media (hover:hover) and (pointer:fine){.service-card:hover{transform:translateY(-3px);box-shadow:0 22px 54px rgba(81,110,148,.14)}.btn:hover{box-shadow:0 13px 28px rgba(65,89,126,.18)}}@media (max-width:620px){.page{padding:calc(16px + env(safe-area-inset-top)) 13px calc(42px + env(safe-area-inset-bottom))}.hero{padding:23px 21px;border-radius:32px}.profile{grid-template-columns:70px 1fr;gap:15px}.avatar{width:70px;height:70px;border-radius:23px}.hero-sub{font-size:13px}.env-bar{margin-top:22px}.section-head{margin:31px 5px 15px}.grid{grid-template-columns:1fr