<!doctype html><html lang="zh-CN"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><meta name="theme-color" content="#eef7ff"><meta name="color-scheme" content="light"><meta name="apple-mobile-web-app-capable" content="yes"><meta name="apple-mobile-web-app-status-bar-style" content="default"><meta name="apple-mobile-web-app-title" content="toolboxpay"><title>toolboxpay · 下雪支付与名片</title><style>:root{color-scheme:light;--ink:#2d3445;--muted:#6f7a8d;--soft:#96a2b5;--line:rgba(62,83,112,.10);--panel:rgba(255,255,255,.76);--shadow:0 24px 64px rgba(83,115,154,.13);--shadow-soft:0 14px 38px rgba(83,115,154,.095);--radius-xl:34px;--radius-lg:28px;--radius-md:18px;--sky-1:#edf7ff;--sky-2:#d8ebff;--sky-ink:#4d78c7;--sky-deep:#466fc0;--sky-deep-2:#5b86d7;--mint-1:#ebf8f4;--mint-2:#d8f0e8;--mint-ink:#438974;--mint-deep:#3f8873;--mint-deep-2:#55a08b;--peach-1:#fff3ed;--peach-2:#ffe1d5;--peach-ink:#ad6957;--peach-deep:#ae6552;--peach-deep-2:#c27a66;--lilac-1:#f5f1ff;--lilac-2:#e6ddfb;--lilac-ink:#7761ae;--lilac-deep:#7058aa;--lilac-deep-2:#876fc0}*{box-sizing:border-box}html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}body{margin:0;min-height:100vh;overflow-x:hidden;font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text","PingFang SC","Microsoft YaHei",sans-serif;color:var(--ink);background:radial-gradient(circle at 14% 5%,rgba(211,233,255,.92),transparent 30%),radial-gradient(circle at 91% 18%,rgba(225,241,255,.94),transparent 33%),radial-gradient(circle at 83% 82%,rgba(232,222,252,.58),transparent 27%),radial-gradient(circle at 8% 88%,rgba(255,225,215,.46),transparent 25%),linear-gradient(158deg,#f7fbff 0%,#eef7ff 45%,#f8f7ff 76%,#fff9f6 100%);text-rendering:optimizeLegibility}body::before,body::after{content:"";position:fixed;z-index:-1;border-radius:999px;filter:blur(18px);pointer-events:none}body::before{width:260px;height:260px;left:-132px;top:34%;opacity:.58;background:#cfeaff}body::after{width:300px;height:300px;right:-168px;top:55%;opacity:.42;background:linear-gradient(145deg,#d9edff,#eadfff)}body.sheet-open{overflow:hidden}button,a{-webkit-tap-highlight-color:transparent}button{font:inherit;border:0;cursor:pointer}a{color:inherit;text-decoration:none}.page{width:min(780px,100%);margin:0 auto;padding:calc(24px + env(safe-area-inset-top)) 18px calc(52px + env(safe-area-inset-bottom))}.hero{position:relative;overflow:hidden;border:1px solid rgba(255,255,255,.9);border-radius:38px;padding:29px;background:linear-gradient(135deg,rgba(255,255,255,.9),rgba(243,249,255,.69)),linear-gradient(155deg,rgba(212,233,255,.55),rgba(255,255,255,.12));backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);box-shadow:var(--shadow)}.hero::before{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(115deg,rgba(255,255,255,.3),transparent 42%)}.hero::after{content:"";position:absolute;width:285px;height:285px;right:-102px;top:-148px;border-radius:50%;background:linear-gradient(150deg,rgba(193,224,255,.84),rgba(226,215,255,.62));box-shadow:inset 0 0 0 1px rgba(255,255,255,.48)}.profile{position:relative;z-index:1;display:grid;grid-template-columns:80px 1fr;align-items:center;gap:19px}.avatar{width:80px;height:80px;border-radius:27px;object-fit:cover;box-shadow:0 15px 34px rgba(56,76,105,.19);border:4px solid rgba(255,255,255,.91)}.name-row{display:flex;align-items:center;flex-wrap:wrap;gap:10px}h1{margin:0;font-size:clamp(30px,7vw,40px);line-height:1.05;letter-spacing:-.04em;font-weight:780}.verified{display:inline-flex;align-items:center;padding:6px 10px;border-radius:999px;color:#617aa8;background:rgba(226,239,255,.88);border:1px solid rgba(255,255,255,.72);font-size:11px;font-weight:750;box-shadow:0 6px 16px rgba(81,112,156,.08)}.hero-sub{margin:9px 0 0;max-width:420px;color:var(--muted);font-size:14px;line-height:1.65}.env-bar{position:relative;z-index:1;margin-top:25px;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:15px 16px;border-radius:20px;background:rgba(248,252,255,.72);border:1px solid rgba(255,255,255,.88);box-shadow:inset 0 1px 0 rgba(255,255,255,.86),0 9px 22px rgba(86,118,157,.06)}.env-title{font-size:11px;color:var(--soft);letter-spacing:.02em}.env-value{margin-top:3px;font-size:14px;font-weight:760;color:#34445c}.env-dot{width:10px;height:10px;flex:0 0 auto;border-radius:50%;background:#77cdb5;box-shadow:0 0 0 6px rgba(119,205,181,.16),0 0 18px rgba(119,205,181,.25)}.section-head{display:flex;align-items:end;justify-content:space-between;gap:16px;margin:36px 6px 17px}.section-head h2{margin:0;font-size:21px;letter-spacing:-.025em}.section-head p{margin:0 0 2px;color:var(--soft);font-size:12px;text-align:right}.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:17px}.service-card{--tone-1:#fff;--tone-2:#f7f7f7;--tone-ink:var(--ink);--tone-deep:#4d596c;--tone-deep-2:#667387;position:relative;display:flex;min-width:0;min-height:294px;ov