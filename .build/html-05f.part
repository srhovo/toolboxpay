('visibilitychange', markHidden);
window.addEventListener('pagehide', markPageHide, { once: true });
window.setTimeout(() => {
document.removeEventListener('visibilitychange', markHidden);
if (!switchedAway && document.visibilityState === 'visible') openSheet('wechatGuide');
}, 1450);
location.href = WECHAT_SCHEME;
