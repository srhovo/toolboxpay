;gap:14px}.service-card{min-height:282px;padding:21px;border-radius:27px}.service-card h3{margin-top:21px}.actions{padding-top:22px}.btn-row{grid-template-columns:1fr 1fr}.note-card{margin-top:16px;padding:19px}.sheet{padding-left:10px;padding-right:10px}}@media (max-width:370px){.btn-row,.guide-actions{grid-template-columns:1fr}.profile{grid-template-columns:60px 1fr}.avatar{width:60px;height:60px;border-radius:20px}.hero{padding:20px 18px}.verified{padding:5px 8px}}@media (prefers-reduced-motion:reduce){*,*::before,*::after{scroll-behavior:auto !important;transition:none !important;animation:none !important}}</style></head><body><main class="page"><header class="hero"><div class="profile"><img class="avatar" src="data:image/webp;base64," alt="下雪头像"><div><div class="name-row"><h1>下雪</h1><span class="verified">个人名片</span></div><p class="hero-sub">支付与联系，一页轻松抵达</p></div></div><div class="env-bar" aria-live="polite"><div><div class="env-title">当前打开环境</div><div class="env-value" id="envValue">正在检测…</div></div><span class="env-dot" aria-hidden="true"></span></div><