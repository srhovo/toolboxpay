<!doctype html><html lang="zh-CN"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><meta name="theme-color" content="#eef7ff"><meta name="color-scheme" content="light"><meta name="apple-mobile-web-app-capable" content="yes"><meta name="apple-mobile-web-app-status-bar-style" content="default"><meta name="apple-mobile-web-app-title" content="toolboxpay"><title>toolboxpay · 下雪支付与名片</title><style>:root{color-scheme:light;--ink:#2d3445;--muted:#6f7a8d;--soft:#96a2b5;--line:rgba(62,83,112,.10);--panel:rgba(255,255,255,.76);--shadow:0 24px 64px rgba(83,115,154,.13);--shadow-soft:0 14px 38px rgba(83,115,154,.095);--radius-xl:34px;--radius-lg:28px;--radius-md:18px;--sky-1:#edf7ff;--sky-2:#d8ebff;--sky-ink:#4d78c7;--sky-deep:#466fc0;--sky-deep-2:#5b86d7;--mint-1:#ebf8f4;--mint-2:#d8f0e8;--mint-ink:#438974;--mint-deep:#3f8873;--mint-deep-2:#55a08b;--peach-1:#fff3ed;--peach-2:#ffe1d5;--peach-ink:#ad6957;--peach-deep:#ae6552;--peach-deep-2:#c27a66;--lilac-1:#f5f1ff;--lilac-2:#e6ddfb;--lilac-ink:#7761ae;--lilac-deep:#7058aa;--lilac-deep-2:#876fc0}*{box-sizing:border-box}html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}body{margin:0;min-height:100vh;overflow-x:hidden;font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text","PingFang SC","Microsoft YaHei",sans-serif;color:var(--ink);background:radial-gradient(circle at 14% 5%,rgba(211,233,255,.92),transparent 30%),radial-gradient(circle at 91% 18%,rgba(225,241,255,.94),transparent 33%),radial-gradient(circle at 83% 82%,rgba(232,222,252,.58),transparent 27%),radial-gradient(circle at 8% 88%,rgba(255,225,215,.46),transparent 25%),linear-gradient(158deg,#f7fbff 0%,#eef7ff 45%,#f8f7ff 76%,#fff9f6 100%);text-rendering:optimizeLegibility}body::before,body::after{content:"";position:fixed;z-index:-1;border-radius:999px;filter:blur(18px);pointer-events:none}body::before{width:260px;height:260px;left:-132px;top:34%;opacity:.58;background:#cfeaff}body::after{width:300px;height:300px;right:-168px;top:55%;opacity:.42;background:linear-gradient(145deg,#d9edff,#eadfff)}body.sheet-open{overflow:hidden}button,a{-webkit-tap-highlight-color:transparent}button{font:inherit;border:0;cursor:pointer}a{color:inherit;text-decoration:none}.page{width:min(780px,100%);margin:0 auto;padding:calc(24px + env(safe-area-inset-top)) 18px calc(52px + env(safe-area-inset-bottom))}.hero{position:relative;overflow:hidden;border:1px solid rgba(255,255,255,.9);border-radius:38px;padding:29px;background:linear-gradient(135deg,rgba(255,255,255,.9),rgba(243,249,255,.69)),linear-gradient(155deg,rgba(212,233,255,.55),rgba(255,255,255,.12));backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);box-shadow:var(--shadow)}.hero::before{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(115deg,rgba(255,255,255,.3),transparent 42%)}.hero::after{content:"";position:absolute;width:285px;height:285px;right:-102px;top:-148px;border-radius:50%;background:linear-gradient(150deg,rgba(193,224,255,.84),rgba(226,215,255,.62));box-shadow:inset 0 0 0 1px rgba(255,255,255,.48)}.profile{position:relative;z-index:1;display:grid;grid-template-columns:80px 1fr;align-items:center;gap:19px}.avatar{width:80px;height:80px;border-radius:27px;object-fit:cover;box-shadow:0 15px 34px rgba(56,76,105,.19);border:4px solid rgba(255,255,255,.91)}.name-row{display:flex;align-items:center;flex-wrap:wrap;gap:10px}h1{margin:0;font-size:clamp(30px,7vw,40px);line-height:1.05;letter-spacing:-.04em;font-weight:780}.verified{display:inline-flex;align-items:center;padding:6px 10px;border-radius:999px;color:#617aa8;background:rgba(226,239,255,.88);border:1px solid rgba(255,255,255,.72);font-size:11px;font-weight:750;box-shadow:0 6px 16px rgba(81,112,156,.08)}.hero-sub{margin:9px 0 0;max-width:420px;color:var(--muted);font-size:14px;line-height:1.65}.env-bar{position:relative;z-index:1;margin-top:25px;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:15px 16px;border-radius:20px;background:rgba(248,252,255,.72);border:1px solid rgba(255,255,255,.88);box-shadow:inset 0 1px 0 rgba(255,255,255,.86),0 9px 22px rgba(86,118,157,.06)}.env-title{font-size:11px;color:var(--soft);letter-spacing:.02em}.env-value{margin-top:3px;font-size:14px;font-weight:760;color:#34445c}.env-dot{width:10px;height:10px;flex:0 0 auto;border-radius:50%;background:#77cdb5;box-shadow:0 0 0 6px rgba(119,205,181,.16),0 0 18px rgba(119,205,181,.25)}.section-head{display:flex;align-items:end;justify-content:space-between;gap:16px;margin:36px 6px 17px}.section-head h2{margin:0;font-size:21px;letter-spacing:-.025em}.section-head p{margin:0 0 2px;color:var(--soft);font-size:12px;text-align:right}.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:17px}.service-card{--tone-1:#fff;--tone-2:#f7f7f7;--tone-ink:var(--ink);--tone-deep:#4d596c;--tone-deep-2:#667387;position:relative;display:flex;min-width:0;min-height:294px;overflow:hidden;flex-direction:column;padding:23px;border-radius:var(--radius-lg);border:1px solid rgba(255,255,255,.9);background:linear-gradient(125deg,rgba(255,255,255,.54),transparent 46%),linear-gradient(148deg,var(--tone-1),var(--tone-2));box-shadow:var(--shadow-soft);transition:transform .22s ease,box-shadow .22s ease;isolation:isolate}.service-card::before{content:"";position:absolute;z-index:-1;width:170px;height:170px;left:-108px;top:-103px;border-radius:50%;background:rgba(255,255,255,.48)}.service-card::after{content:"";position:absolute;z-index:-1;width:172px;height:172px;right:-77px;bottom:-88px;border-radius:50%;background:rgba(255,255,255,.39);box-shadow:inset 0 0 0 1px rgba(255,255,255,.22)}.service-card:active{transform:scale(.988)}.service-card.is-recommended{box-shadow:0 22px 54px rgba(81,117,166,.16);border-color:rgba(255,255,255,.98)}.service-card.is-target{outline:3px solid rgba(255,255,255,.9);box-shadow:0 0 0 5px rgba(91,134,215,.13),var(--shadow)}.mint{--tone-1:var(--mint-1);--tone-2:var(--mint-2);--tone-ink:var(--mint-ink);--tone-deep:var(--mint-deep);--tone-deep-2:var(--mint-deep-2)}.sky{--tone-1:var(--sky-1);--tone-2:var(--sky-2);--tone-ink:var(--sky-ink);--tone-deep:var(--sky-deep);--tone-deep-2:var(--sky-deep-2)}.peach{--tone-1:var(--peach-1);--tone-2:var(--peach-2);--tone-ink:var(--peach-ink);--tone-deep:var(--peach-deep);--tone-deep-2:var(--peach-deep-2)}.lilac{--tone-1:var(--lilac-1);--tone-2:var(--lilac-2);--tone-ink:var(--lilac-ink);--tone-deep:var(--lilac-deep);--tone-deep-2:var(--lilac-deep-2)}.card-top{position:relative;z-index:1;display:flex;align-items:flex-start;justify-content:space-between;gap:12px}.icon-box{display:grid;place-items:center;width:51px;height:51px;border-radius:18px;color:var(--tone-ink);background:rgba(255,255,255,.68);box-shadow:inset 0 0 0 1px rgba(255,255,255,.78),0 8px 20px rgba(75,95,126,.07)}.icon-box svg{width:27px;height:27px}.tag{min-height:27px;display:inline-flex;align-items:center;padding:6px 11px;border-radius:999px;color:var(--tone-ink);background:rgba(255,255,255,.62);border:1px solid rgba(255,255,255,.7);font-size:10px;font-weight:800;letter-spacing:.04em}.tag.recommend{display:none}.is-recommended .tag.default{display:none}.is-recommended .tag.recommend{display:inline-flex}.service-card h3{position:relative;z-index:1;margin:25px 0 8px;font-size:23px;line-height:1.25;letter-spacing:-.03em}.service-card .desc{position:relative;z-index:1;margin:0;min-height:44px;color:rgba(45,52,69,.66);font-size:13px;line-height:1.68}.account{position:relative;z-index:1;margin-top:13px;color:var(--tone-ink);font-size:12px;font-weight:760}.actions{position:relative;z-index:1;display:grid;gap:9px;margin-top:auto;padding-top:24px}.btn{min-height:49px;display:inline-flex;align-items:center;justify-content:center;gap:7px;border-radius:16px;padding:0 15px;font-size:13px;font-weight:760;transition:transform .16s ease,opacity .16s ease,background .16s ease,box-shadow .16s ease}.btn:active{transform:scale(.975);opacity:.88}.btn.primary{color:#fff;background:linear-gradient(135deg,var(--tone-deep),var(--tone-deep-2));box-shadow:0 11px 24px rgba(65,89,126,.16)}.btn.secondary{color:var(--tone-ink);background:rgba(255,255,255,.67);border:1px solid rgba(255,255,255,.8);box-shadow:inset 0 1px 0 rgba(255,255,255,.74)}.btn-row{display:grid;grid-template-columns:1fr 1fr;gap:9px}.note-card{margin-top:18px;padding:20px 21px;border-radius:23px;border:1px solid rgba(255,255,255,.88);background:linear-gradient(145deg,rgba(255,255,255,.75),rgba(238,247,255,.68));backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);box-shadow:var(--shadow-soft)}.note-card strong{display:block;margin-bottom:7px;font-size:13px}.note-card p{margin:0;color:var(--muted);font-size:12px;line-height:1.75}.footer{padding:32px 8px 6px;text-align:center;color:var(--soft);font-size:11px;line-height:1.8}.sheet{position:fixed;inset:0;z-index:50;display:flex;align-items:flex-end;justify-content:center;padding:16px;padding-bottom:calc(16px + env(safe-area-inset-bottom));background:rgba(45,58,78,.28);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);opacity:0;pointer-events:none;transition:opacity .24s ease}.sheet[hidden]{display:none}.sheet.show{opacity:1;pointer-events:auto}.sheet-panel{width:min(560px,100%);max-height:min(86vh,820px);overflow:auto;border-radius:32px;background:linear-gradient(180deg,#fcfeff,#f8fbff);border:1px solid rgba(255,255,255,.92);box-shadow:0 28px 78px rgba(42,58,82,.27);transform:translateY(18px) scale(.985);transition:transform .24s ease}.sheet.show .sheet-panel{transform:translateY(0) scale(1)}.sheet-head{position:sticky;top:0;z-index:2;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:19px 20px 15px;background:rgba(250,253,255,.93);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--line)}.sheet-title{min-width:0}.sheet-title h2{margin:0;font-size:18px}.sheet-title p{margin:4px 0 0;color:var(--soft);font-size:11px}.close{width:38px;height:38px;flex:0 0 auto;display:grid;place-items:center;border-radius:50%;color:var(--muted);background:#eef5fb;font-size:21px}.qr-wrap{padding:18px;background:linear-gradient(145deg,#eef7ff,#f8fbff)}.qr-image{display:block;width:100%;max-height:64vh;object-fit:contain;border-radius:21px;background:#fff;box-shadow:0 12px 32px rgba(65,88,119,.1);-webkit-touch-callout:default;user-select:auto}.sheet-foot{display:grid;gap:11px;padding:16px 19px 20px}.sheet-hint{margin:0;color:var(--muted);font-size:12px;line-height:1.7;text-align:center}.sheet-foot .btn{width:100%;color:#fff;background:linear-gradient(135deg,#4a6f9f,#6387b8)}.guide-body{padding:20px}.guide-lead{margin:0 0 16px;color:var(--m